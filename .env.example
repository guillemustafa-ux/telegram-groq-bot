# ============================================================
#  Configuración del bot — copiá este archivo a .env y completá
# ============================================================

# --- Obligatorias -------------------------------------------

# Token del bot, te lo da @BotFather en Telegram.
TELEGRAM_TOKEN=

# API key de Groq -> https://console.groq.com/keys  (empieza con gsk_)
GROQ_API_KEY=

# --- Modelo (opcional) --------------------------------------

# Modelos vigentes en Groq:
#   llama-3.3-70b-versatile  -> mejor calidad (default)
#   llama-3.1-8b-instant     -> más rápido y barato
GROQ_MODEL=llama-3.3-70b-versatile
TEMPERATURE=0.7
MAX_TOKENS=600

# --- Personalidad del bot (system prompt) -------------------
# Dos formas de definir la personalidad SIN tocar código:
#
#   1) SYSTEM_PROMPT: escribís el texto directo acá (tiene prioridad).
#   2) SYSTEM_PROMPT_FILE: apuntás a un archivo .txt en prompts/.
#
# Si dejás ambos vacíos, usa prompts/generic.txt.
# Ejemplos de archivos incluidos: prompts/generic.txt, prompts/crypto.txt,
# prompts/business.txt

# SYSTEM_PROMPT=Sos un asistente que responde solo sobre cocina italiana.
SYSTEM_PROMPT_FILE=prompts/generic.txt

# --- Otros (opcional) ---------------------------------------

# Nombre que el bot usa en el mensaje de /start.
BOT_NAME=Asistente

# Cantidad de mensajes recientes que recuerda por usuario.
MAX_HISTORY=10
